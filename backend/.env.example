# Configuração do Processador de Documentos
# Copie este arquivo para `.env` e preencha os valores. NUNCA versione o `.env`.

# Pasta de dados única (banco SQLite + CAS). Se vazio, usa o padrão da plataforma:
#   Windows: %ProgramData%\ProcessadorDocumentos
#   Outros:  ~/.processador_documentos
DATA_DIR=

# Connection string do banco (SQLAlchemy). Se vazio, deriva um SQLite dentro de DATA_DIR.
# Ex. Postgres (modo servidor): postgresql+psycopg://usuario:senha@host:5432/banco
DATABASE_URL=

# Chave da API OpenAI (uma por instância/cliente). Tratada como segredo.
OPENAI_API_KEY=
